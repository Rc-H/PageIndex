# =============================================================================
# LLM Provider
# Choose one: openai | azure_openai | openai_compatible | ollama | vllm
# =============================================================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-2024-11-20

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=                        # optional, leave blank for default

# --- Azure OpenAI ---
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_BASE_URL=               # e.g. https://<resource>.openai.azure.com
# AZURE_OPENAI_ENDPOINT=               # alternative to AZURE_OPENAI_BASE_URL

# --- OpenAI-Compatible (Ollama / vLLM / other) ---
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_BASE_URL=          # e.g. http://localhost:11434/v1

# =============================================================================
# Service settings
# =============================================================================
PAGEINDEX_WORKER_CONCURRENCY=2
PAGEINDEX_LIBREOFFICE_COMMAND=libreoffice
PAGEINDEX_DOC_CONVERSION_TIMEOUT_SECONDS=120
PAGEINDEX_REMOTE_FILE_TIMEOUT_SECONDS=60
PAGEINDEX_CALLBACK_TIMEOUT_SECONDS=30
PAGEINDEX_CALLBACK_RETRY_COUNT=3
PAGEINDEX_ATTACHMENT_UPLOAD_DOMAIN=
# PAGEINDEX_ATTACHMENT_UPLOAD_API_KEY=


# =============================================================================
# Seq Logging settings
# =============================================================================
PAGEINDEX_SEQ_URL=http://localhost:5341
# PAGEINDEX_SEQ_API_KEY=
PAGEINDEX_LOG_LEVEL=INFO
PAGEINDEX_LOG_TIMEOUT_SECONDS=5
